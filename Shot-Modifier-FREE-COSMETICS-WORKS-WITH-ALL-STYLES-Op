local function GiveLocalCosmetic(cosmeticName)
    local char = LocalPlayer.Character
    local torso = char:FindFirstChild("Torso") or char:FindFirstChild("UpperTorso") or char:FindFirstChild("HumanoidRootPart")
    if not char or not torso then return end
    
    local targetSource = CosmeticsFolder and CosmeticsFolder:FindFirstChild(cosmeticName)
    if not targetSource then
        Rayfield:Notify({ Title = "Error", Content = "Cosmetic folder asset not found on client.", Duration = 3 })
        return
    end
    
    for _, v in ipairs(torso:GetChildren()) do
        if v:GetAttribute("IsLocalMenuCosmetic") then v:Destroy() end
    end

    pcall(function()
        local emitModule = require(ReplicatedStorage.Shared.EmitModule)
        local partAsset = targetSource:FindFirstChild("Part")
        if partAsset then
            local clonedPart = partAsset:Clone()
            clonedPart:SetAttribute("IsLocalMenuCosmetic", true)
            local referenceTorso = targetSource:FindFirstChild("Torso")
            if referenceTorso then
                clonedPart:PivotTo(torso.CFrame * referenceTorso.CFrame:ToObjectSpace(clonedPart:GetPivot()))
            else
                clonedPart.CFrame = torso.CFrame
            end
            clonedPart.Parent = torso
            CollectionService:AddTag(clonedPart, "Cosmetic" .. cosmeticName)
            local weld = Instance.new("WeldConstraint")
            weld.Part0 = torso; weld.Part1 = clonedPart; weld.Parent = clonedPart
        end
        
        local torsoSource = targetSource:FindFirstChild("Torso")
        if torsoSource then
            local trackedEmitters = {}
            for _, element in ipairs(torsoSource:GetChildren()) do
                local clonedElement = element:Clone()
                clonedElement:SetAttribute("IsLocalMenuCosmetic", true)
                clonedElement.Parent = torso
                table.insert(trackedEmitters, clonedElement)
                CollectionService:AddTag(clonedElement, "Cosmetic" .. cosmeticName)
            end
            
            task.spawn(function()
                while char and char.Parent and torso and torso.Parent do
                    for _, emitter in ipairs(trackedEmitters) do
                        if emitter and emitModule and emitModule.emit then emitModule.emit(emitter) end
                    end
                    task.wait(1.5)
                end
            end)
        end
    end)
end

-- Function to attempt triggering the Cmdr Global command (Requires Server Admin to succeed)
local function AttemptGlobalCosmetic(cosmeticName)
    pcall(function()
        local cmdrModule = ReplicatedStorage:FindFirstChild("CmdrClient")
        if cmdrModule then
            local Cmdr = require(cmdrModule)
            if Cmdr and Cmdr.Dispatcher then
                -- Ask Cmdr to evaluate and run the command just like if we typed it in the UI
                Cmdr.Dispatcher:EvaluateAndRun("GlobalCosmetic " .. cosmeticName)
                Rayfield:Notify({ Title = "Attempted", Content = "Sent GlobalCosmetic request to server via Cmdr.", Duration = 4 })
            else
                Rayfield:Notify({ Title = "Failed", Content = "Found CmdrClient but could not access Dispatcher.", Duration = 3 })
            end
        else
            Rayfield:Notify({ Title = "Failed", Content = "Could not find CmdrClient in ReplicatedStorage.", Duration = 3 })
        end
    end)
end

