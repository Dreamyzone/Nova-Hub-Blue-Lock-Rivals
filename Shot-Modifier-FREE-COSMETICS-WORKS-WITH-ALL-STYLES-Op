-- Hook for Kaiser Volley 
pcall(function()
    local rawVolleyFunc = require(ReplicatedStorage:WaitForChild("Controllers"):WaitForChild("AbilityController"):WaitForChild("AbilitiesClient"):WaitForChild("Kaiser"):WaitForChild("KaiserVolley"))
    if hook and type(rawVolleyFunc) == "function" then
        hook(rawVolleyFunc, function(p1, p2, p3)
            if getgenv().NoKaiserVolleyCooldown and p1 then p1.AbilityThree = 0 end
            if getgenv().BypassKaiserVolleyCheck then
                local v1 = if p3 then p3:FindFirstChild("HumanoidRootPart") else p3
                if not (v1 and workspace.CurrentCamera) then return end
                if p1.ABC then p1.ABC:Clean() end
                
                local targetCharacter = nil
                for _, player in pairs(Players:GetPlayers()) do
                    if player.Team == p2.Team and player ~= p2 and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                        targetCharacter = player.Character; break
                    end
                end
                if not targetCharacter then targetCharacter = workspace:FindFirstChild("PassRig") or p3 end
                
                if targetCharacter then
                    p1.StatesController.States.Ability = true
                    local configVolley = (balanceSuccess and AbilityBalancing.KaiserVolley) or { ShotTiltVector = Vector3.new(0, 0.2, 0), ShotPower = 180, Cooldown = 15 }
                    
                    if p1.AbilityCooldown then p1:AbilityCooldown("3", configVolley.Cooldown) end
                    p1.AbilityService.Ability:Fire("KaiserVolley", targetCharacter)
                    
                    p1.ABC:Connect(p1.AbilityService.Ability, function(ballInstance, curveVector, actionState)
                        if actionState ~= "start" then return end
                        local Promise = require(ReplicatedStorage:WaitForChild("Packages"):WaitForChild("Promise"))
                        local startTick = tick()
                        local heartbeatConn
                        
                        Promise.new(function(resolve)
                            heartbeatConn = p1.ABC:Connect(game:GetService("RunService").Heartbeat, function()
                                if tick() > startTick + 5 or (not ballInstance or ballInstance.OnPlayer.Value) then
                                    heartbeatConn:Disconnect(); resolve()
                                end
                            end)
                        end):catch(warn)
                        
                        p1.Animations:StopAnims()
                        p1.Animations.Abilities.KaiserVolley.Priority = Enum.AnimationPriority.Action4
                        p1.Animations.Abilities.KaiserVolley:Play()
                        p1.Animations.Ball.KaiserVolley.Priority = Enum.AnimationPriority.Action4
                        p1.Animations.Ball.KaiserVolley:Play()
                        p1.ABC:Clean()
                        
                        local waitTimeout = 0
                        while p3.Values.HasBall.Value and waitTimeout < 1.5 do waitTimeout = waitTimeout + task.wait() end
                        
                        p1.StatesController.States.Ability = false
                        local cVec = typeof(curveVector) == "Vector3" and curveVector or Vector3.zero
                        ballInstance.AssemblyLinearVelocity = (workspace.CurrentCamera.CFrame.LookVector + configVolley.ShotTiltVector + (cVec / 2)) * configVolley.ShotPower
                        
                        task.delay(0.1, function()
                            local trajectoryLerp = -40
                            p1.ABC:Connect(game:GetService("RunService").Heartbeat, function(deltaTime)
                                -- FIXED: Safety check to ensure ballInstance still exists in the workspace
                                if not ballInstance or not ballInstance.Parent then 
                                    p1.ABC:Clean()
                                    return 
                                end
                                
                                trajectoryLerp = trajectoryLerp + 25 * deltaTime
                                if trajectoryLerp >= -25 then p1.ABC:Clean() end
                                ballInstance.AssemblyLinearVelocity = ballInstance.AssemblyLinearVelocity:Lerp(ballInstance.AssemblyLinearVelocity + (cVec * trajectoryLerp), 6.5 * deltaTime)
                            end)
                        end)
                        
                        local actualBall = ReplicatedStorage:FindFirstChild("Football") and ReplicatedStorage.Football.Value or ballInstance
                        p1.BallController:DragBall(actualBall)
                    end)
                    return
                end
            end
            return rawVolleyFunc(p1, p2, p3)
        end)
    end
end)

